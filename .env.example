# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

# --- Login "Skip" (optional) ---
# Recommended: Supabase → Authentication → Providers → enable Anonymous. Skip uses that first (no secrets).
# Optional server fallback: normal Auth user credentials (only used if anonymous fails).
DEMO_LOGIN_EMAIL=
DEMO_LOGIN_PASSWORD=
# When true, allows POST /api/auth/demo-skip in production (not required for Anonymous-only Skip).
DEMO_SKIP_AUTH=false
# Set to false to hide the Skip button (default: shown).
NEXT_PUBLIC_SHOW_AUTH_SKIP=

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Inbox / webhooks ---
INBOX_API_KEY=
DEFAULT_AGENT_USER_ID=
CHATWOOT_WEBHOOK_TOKEN=
HELPWISE_WEBHOOK_TOKEN=

# --- OpenAI (optional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Shopify (catalog sync; used by `src/lib/shopify.ts`) ---
# Admin API: https://shopify.dev/docs/api/admin-graphql
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=

# --- Polar (https://polar.sh) — billing / subscriptions ---
# Create an access token in the Polar dashboard (Organization settings → Developers).
POLAR_ACCESS_TOKEN=
# Optional: organization ID or slug if your integration needs it
POLAR_ORGANIZATION_ID=

# --- Vendura ---
# Set when your Vendura integration docs specify the auth shape (API key, base URL, etc.).
VENDURA_API_KEY=
VENDURA_API_BASE_URL=

# --- Stripe (payments) ---
# https://dashboard.stripe.com/apikeys
# Use `sk_test_...` / `pk_test_...` in development; live keys only in production.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Snipcart / SamCart (marketplace checkout; can also be stored in app_settings via Integrations UI) ---
# Public Snipcart key is safe to expose to the browser if prefixed NEXT_PUBLIC_ (optional duplicate of DB setting).
NEXT_PUBLIC_SNIPCART_PUBLIC_API_KEY=
